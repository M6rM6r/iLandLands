# =============================================================================
# Gulf Lands Frontend Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# API Endpoints
# ─────────────────────────────────────────────────────────────────────────────

# Primary PHP API (auth, listings, inquiries, analytics)
VITE_API_BASE_URL=http://localhost/api/v1
# Production: https://api.gulflands.com/api/v1

# Python API (valuation engine, AI recommendations)
VITE_PYTHON_API_URL=http://localhost:8000/v1
# Production: https://python-api.gulflands.com/v1

# Recommendation microservice
VITE_RECO_SERVICE_URL=http://localhost:8001/v1
# Production: https://reco.gulflands.com/v1

# ─────────────────────────────────────────────────────────────────────────────
# App Configuration
# ─────────────────────────────────────────────────────────────────────────────

VITE_APP_NAME=Gulf Lands
VITE_APP_VERSION=2.0.0

# Firebase config (for auth, hosting, analytics)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=ilandlands.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ilandlands
VITE_FIREBASE_STORAGE_BUCKET=ilandlands.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Google Gemini AI (for listing descriptions)
VITE_GEMINI_API_KEY=your_gemini_api_key

# ─────────────────────────────────────────────────────────────────────────────
# Feature Flags
# ─────────────────────────────────────────────────────────────────────────────

VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_AI_DESCRIPTIONS=true
VITE_ENABLE_WHATSAPP_INTEGRATION=true
VITE_ENABLE_PAYMENTS=true
