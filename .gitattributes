# Normalize line endings to LF on commit, checkout to native on Windows
* text=auto eol=lf

# Dart / Flutter sources — always LF
*.dart text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.sh   text eol=lf

# Binary assets — no line-ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ttf  binary
*.otf  binary
*.woff binary
*.woff2 binary
