# API Configuration
API_BASE_URL=https://api.gulflands.com/v1
PYTHON_API_URL=http://localhost:8000
RECO_SERVICE_URL=http://localhost:8001
ANALYTICS_SERVICE_URL=http://localhost:8002
API_TIMEOUT=30000

# Flutter dart-define equivalents (dev):
# flutter run --dart-define=PYTHON_API_URL=http://localhost:8000 --dart-define=GEMINI_API_KEY=...

# Authentication
JWT_SECRET=your-jwt-secret-key-change-this-in-production
GEMINI_API_KEY=

# Database
MYSQL_ROOT_PASSWORD=root_password_123
MYSQL_DATABASE=gulflands
MYSQL_USER=gulflands_user
MYSQL_PASSWORD=secure_password_123
POSTGRES_USER=gulflands_user
POSTGRES_PASSWORD=secure_password_123
POSTGRES_DB=gulflands_analytics

# Redis
REDIS_PASSWORD=redis_password_123

# Analytics
ANALYTICS_API_KEY=your-analytics-api-key
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_PROJECT_ID=gulflands-app

# Security
ENCRYPTION_KEY=your-encryption-key-32-chars-long
BIOMETRIC_ENABLED=true

# Environment
ENVIRONMENT=development
DEBUG=true

# Cache Configuration
CACHE_TTL_HOURS=24
MAX_CACHE_SIZE_MB=50

# Ports
APP_PORT=80
PYTHON_API_PORT=8000
RECO_PORT=8001
ANALYTICS_PORT=8002
POSTGRES_PORT=5432
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
