parameters:
    level: 8
    paths:
        - src
        - tests
    ignoreErrors:
        - '#Unsafe usage of new static#'
    bootstrapFiles:
        - vendor/autoload.php
    checkGenericClassInNonGenericObjectType: false
    checkMissingIterableValueType: false
    reportUnmatchedIgnoredErrors: false
    treatPhpDocTypesAsCertain: true
