    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-doctrine": "^1.4",
        "phpstan/phpstan-symfony": "^1.3",
        "phpstan/phpstan-strict-rules": "^1.5",
        "phpstan/phpstan-phpunit": "^1.3",
        "phpstan/extension-installer": "^1.3",
        "squizlabs/php_codesniffer": "^3.7",
        "friendsofphp/php-cs-fixer": "^3.49",
        "phpspec/prophecy-phpunit": "^2.2",
        "mockery/mockery": "^1.6",
        "fakerphp/faker": "^1.23",
        "behat/behat": "^3.14",
        "behat/mink": "^1.11",
        "behat/mink-extension": "^2.5",
        "behat/mink-goutte-driver": "^2.0",
        "behat/mink-selenium2-driver": "^1.6",
        "phpspec/phpspec": "^7.4",
        "pestphp/pest": "^2.34",
        "pestphp/pest-plugin-laravel": "^2.2",
        "pestphp/pest-plugin-parallel": "^1.2",
        "nunomaduro/collision": "^8.1",
        "phpunit/php-code-coverage": "^10.1",
        "sebastian/phpcpd": "^6.0",
        "phpmd/phpmd": "^2.14",
        "pdepend/pdepend": "^2.16",
        "seld/jsonlint": "^4.0",
        "enalean/php-tik": "^1.0",
        "phpmetrics/phpmetrics": "^2.8",
        "infection/infection": "^0.27",
        "phan/phan": "^5.4",
        "vimeo/psalm": "^5.22",
        "psalm/plugin-phpunit": "^0.18",
        "psalm/plugin-symfony": "^5.0",
        "psalm/plugin-doctrine": "^2.2",
        "brianium/paratest": "^7.4",
        "mikey179/vfsstream": "^1.6",
        "phpunit/php-invoker": "^4.0",
        "phpunit/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage",
        "phpstan": "phpstan analyse src tests --level=8",
        "phpcs": "phpcs --standard=PSR12 src tests",
        "phpcbf": "phpcbf --standard=PSR12 src tests",
        "cs-fix": "php-cs-fixer fix src tests",
        "cs-check": "php-cs-fixer fix src tests --dry-run --diff",
        "phpmd": "phpmd src text cleancode,codesize,controversial,design,naming,unusedcode",
        "phpcpd": "phpcpd src",
        "infection": "infection --test-framework=phpunit --threads=4",
        "metrics": "phpmetrics --report-html=metrics src",
        "psalm": "psalm --show-info=true",
        "quality": [
            "@phpstan",
            "@phpcs",
            "@phpmd",
            "@phpcpd"
        ],
        "ci": [
            "@test",
            "@quality"
        ]
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}