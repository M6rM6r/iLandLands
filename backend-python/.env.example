# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/gulflands

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# CORS Configuration
ALLOWED_ORIGINS=https://gulflands.com,https://www.gulflands.com

# Rate Limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60

# Analytics
ANALYTICS_API_KEY=your-analytics-api-key